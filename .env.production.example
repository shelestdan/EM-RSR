# Runtime
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://em-pcp.ru

# Payload CMS / portal / admin
# Must be PostgreSQL. MySQL from shared hosting is not compatible with current Payload adapter.
DATABASE_URI=postgresql://user:password@host:5432/em_rsr
PAYLOAD_SECRET=replace-with-random-string-min-32-chars
PAYLOAD_API_KEY=replace-with-random-api-key
# Local server URL for internal Payload API calls. Use 127.0.0.1 on VPS.
PAYLOAD_INTERNAL_URL=http://127.0.0.1:3000

# Email notifications
SMTP_HOST=smtp.example.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=site@example.ru
SMTP_PASS=replace-with-mail-password
SMTP_FROM=site@example.ru
NOTIFY_EMAIL=owner@example.ru

# Telegram notifications, optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Pages only. Keep empty/false on normal hosting.
GITHUB_PAGES=false
